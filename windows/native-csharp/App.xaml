<Application x:Class="CCP.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ── OBSIDIAN DESIGN SYSTEM ── -->

            <!-- Backgrounds: true black spectrum -->
            <SolidColorBrush x:Key="VoidBrush" Color="#000000" />
            <SolidColorBrush x:Key="BaseBrush" Color="#0A0A0A" />
            <SolidColorBrush x:Key="Surface1" Color="#111111" />
            <SolidColorBrush x:Key="Surface2" Color="#171717" />
            <SolidColorBrush x:Key="Surface3" Color="#1E1E1E" />
            <SolidColorBrush x:Key="SurfaceHover" Color="#242424" />

            <!-- Borders -->
            <SolidColorBrush x:Key="BorderSubtle" Color="White" Opacity="0.07" />
            <SolidColorBrush x:Key="BorderMed" Color="White" Opacity="0.12" />
            <SolidColorBrush x:Key="BorderBright" Color="White" Opacity="0.18" />

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F5" />
            <SolidColorBrush x:Key="TextSecondary" Color="#A3A3A3" />
            <SolidColorBrush x:Key="TextMuted" Color="#636363" />

            <!-- Status -->
            <SolidColorBrush x:Key="StatusGreen" Color="#34D399" />
            <SolidColorBrush x:Key="StatusAmber" Color="#FBBF24" />
            <SolidColorBrush x:Key="StatusRed" Color="#F87171" />

            <!-- Fonts -->
            <FontFamily x:Key="Display">Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="Body">Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="Mono">Cascadia Mono, Consolas</FontFamily>

            <!-- Radii -->
            <CornerRadius x:Key="R6">6</CornerRadius>
            <CornerRadius x:Key="R8">8</CornerRadius>
            <CornerRadius x:Key="R10">10</CornerRadius>
            <CornerRadius x:Key="R14">14</CornerRadius>
            <CornerRadius x:Key="R100">100</CornerRadius>

            <!-- Shadow -->
            <DropShadowEffect x:Key="SubtleShadow" ShadowDepth="4" BlurRadius="16" Direction="270" Color="Black" Opacity="0.5" />

            <!-- ── GHOST BUTTON ── -->
            <Style x:Key="GhostBtn" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource Body}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{StaticResource Surface2}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R8}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <Border.RenderTransform><ScaleTransform x:Name="S" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                <Border.RenderTransformOrigin><Point X="0.5" Y="0.5"/></Border.RenderTransformOrigin>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderMed}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions><BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.06"/>
                                    </Storyboard></BeginStoryboard></Trigger.EnterActions>
                                    <Trigger.ExitActions><BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    </Storyboard></BeginStoryboard></Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── WHITE ACCENT BUTTON ── -->
            <Style x:Key="AccentBtn" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource Body}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#0A0A0A" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="White" CornerRadius="{StaticResource R8}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <Border.RenderTransform><ScaleTransform x:Name="S" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                <Border.RenderTransformOrigin><Point X="0.5" Y="0.5"/></Border.RenderTransformOrigin>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#D4D4D4"/>
                                    <Trigger.EnterActions><BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.06"/>
                                    </Storyboard></BeginStoryboard></Trigger.EnterActions>
                                    <Trigger.ExitActions><BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="S" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    </Storyboard></BeginStoryboard></Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.25"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Default button inherits ghost -->
            <Style TargetType="Button" BasedOn="{StaticResource GhostBtn}">
                <Setter Property="Padding" Value="14,8"/>
            </Style>

            <!-- ── GLASS TAB CONTROL ── -->
            <Style x:Key="TabCtrl" TargetType="TabControl">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource Surface1}" CornerRadius="{StaticResource R8}" Padding="3" Margin="0,0,0,12">
                                    <TabPanel IsItemsHost="True"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TabBtn" TargetType="TabItem">
                <Setter Property="FontFamily" Value="{StaticResource Body}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="{StaticResource R6}" Padding="14,7" Margin="2,0">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface3}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── LISTBOX ── -->
            <Style TargetType="ListBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="{StaticResource R8}" Padding="1">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="White" Opacity="0.04"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── SCROLLBAR (thin) ── -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="5"/>
                <Setter Property="MinWidth" Value="5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource TextMuted}" CornerRadius="2.5" Opacity="0.4" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
