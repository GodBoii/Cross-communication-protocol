<Window x:Class="CCP.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CCP.Windows.Models"
        Title="CCP Windows" Width="1040" Height="680" MinWidth="920" MinHeight="580"
        Background="#F6F7F9">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="CCP" FontSize="34" FontWeight="Bold" Foreground="#17202E"/>
                <TextBlock Text="Native Windows bridge for nearby Android and desktop devices"
                           FontSize="14" Foreground="#627085" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#EAF1FF" CornerRadius="8" Padding="14,10">
                <TextBlock Text="{Binding LocalStatus}" Foreground="#1F4B8F" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,22,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Nearby Devices" FontSize="18" FontWeight="Bold" Foreground="#243044"/>
                        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" />
                    </DockPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Peers}" SelectedItem="{Binding SelectedPeer}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PeerView}">
                                <Border BorderBrush="#E7EAF0" BorderThickness="0,0,0,1" Padding="0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18"
                                                Background="{Binding BadgeBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PlatformInitial}" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DeviceName}" FontSize="15" FontWeight="SemiBold" Foreground="#1F2937"/>
                                            <TextBlock Text="{Binding EndpointLabel}" FontSize="12" Foreground="#6B7280" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Pair" Command="{Binding DataContext.PairCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                            <Button Content="Send File" Command="{Binding DataContext.SendFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" IsEnabled="{Binding Trusted}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Activity" FontSize="18" FontWeight="Bold" Foreground="#243044" Margin="0,0,0,12"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Events}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#394557" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#101827" CornerRadius="8" Padding="12,10">
            <TextBlock Text="{Binding FooterStatus}" Foreground="#EAF0F8"/>
        </Border>
    </Grid>
</Window>

