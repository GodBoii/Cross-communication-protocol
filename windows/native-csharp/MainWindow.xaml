<Window x:Class="CCP.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CCP.Windows.Models"
        Title="CCP Windows" Width="1320" Height="820" MinWidth="1120" MinHeight="700"
        Background="#EEF2F7">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorder" Color="#E3E8F1" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F1A2B" CornerRadius="28" Padding="26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CCP" Foreground="White" FontSize="36" FontWeight="Bold" />
                    <TextBlock Text="Desktop command center for nearby devices" Foreground="#B4C1D5" FontSize="16" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding SelectedPeerLabel}" Foreground="#D6DEEA" FontSize="13" Margin="0,18,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Background="#1C2F4E" CornerRadius="16" Padding="18,12" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Status" Foreground="#93A6C4" FontSize="12" />
                            <TextBlock Text="{Binding LocalStatus}" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Button Content="Refresh discovery" Command="{Binding RefreshCommand}" Background="#E6EEF9" Foreground="#183A67" BorderBrush="{x:Null}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="24" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Text="Nearby devices" FontSize="24" FontWeight="Bold" Foreground="#182334" />
                        <TextBlock DockPanel.Dock="Bottom" Text="Pair once, then browse the phone from your laptop." Foreground="#6B7788" FontSize="13" Margin="0,8,0,0" />
                    </DockPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Peers}" SelectedItem="{Binding SelectedPeer}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PeerView}">
                                <Border Background="#FBFCFE" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="18" Margin="0,0,0,10" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="40" Height="40" CornerRadius="20" Background="{Binding BadgeBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PlatformInitial}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DeviceName}" FontSize="16" FontWeight="SemiBold" Foreground="#1A2332" />
                                            <TextBlock Text="{Binding EndpointLabel}" FontSize="12" Foreground="#69768A" Margin="0,4,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Pair" Command="{Binding DataContext.PairCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Background="White" BorderBrush="#D5DDE9" Foreground="#203450" Margin="0,0,8,0" />
                                            <Button Content="Send" Command="{Binding DataContext.SendFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Background="#16253C" Foreground="White" BorderBrush="{x:Null}" IsEnabled="{Binding Trusted}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="24" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding PanelTitle}" FontSize="28" FontWeight="Bold" Foreground="#182334" />
                            <TextBlock Text="{Binding PanelSubtitle}" FontSize="14" Foreground="#657389" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Reload panel" Command="{Binding RefreshPanelCommand}" Background="#EAF1FB" Foreground="#20406A" BorderBrush="{x:Null}" />
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,18">
                        <Border Background="#F7FAFD" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="18" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Battery" Foreground="#6A778B" FontSize="12" />
                                <TextBlock Text="{Binding BatteryText}" Foreground="#182334" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F7FAFD" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="18" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Storage" Foreground="#6A778B" FontSize="12" />
                                <TextBlock Text="{Binding StorageText}" Foreground="#182334" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F7FAFD" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="18" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Notifications" Foreground="#6A778B" FontSize="12" />
                                <TextBlock Text="{Binding NotificationAccessText}" Foreground="#182334" FontSize="18" FontWeight="Bold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F7FAFD" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="18" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Gallery" Foreground="#6A778B" FontSize="12" />
                                <TextBlock Text="{Binding GalleryAccessText}" Foreground="#182334" FontSize="18" FontWeight="Bold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TabControl Grid.Row="2" Background="Transparent" BorderBrush="#E1E8F1">
                        <TabItem Header="Overview">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DeviceSettings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:RemoteFactView}">
                                            <Border Background="#FBFCFE" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}" Foreground="#66758A" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#182334" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Gallery">
                            <ListBox ItemsSource="{Binding GalleryItems}" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RemoteContentItem}">
                                        <Border Background="#FBFCFE" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#182334" />
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#6A778B" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <TabItem Header="Files">
                            <ListBox ItemsSource="{Binding FileItems}" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RemoteContentItem}">
                                        <Border Background="#FBFCFE" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#182334" />
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#6A778B" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <TabItem Header="Notifications">
                            <ListBox ItemsSource="{Binding NotificationItems}" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RemoteContentItem}">
                                        <Border Background="#FBFCFE" BorderBrush="#E7EDF4" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#182334" />
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#6A778B" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#101827" CornerRadius="18" Padding="14,12">
            <TextBlock Text="{Binding FooterStatus}" Foreground="#E8EEF7" />
        </Border>
    </Grid>
</Window>

