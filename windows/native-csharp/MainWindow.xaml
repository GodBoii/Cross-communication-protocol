<Window x:Class="CCP.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CCP.Windows.Models"
        Title="CCP" Width="1280" Height="780" MinWidth="1060" MinHeight="640"
        Background="{StaticResource VoidBrush}"
        FontFamily="{StaticResource Body}">

    <Window.Resources>
        <Storyboard x:Key="Entrance">
            <DoubleAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.05">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Sidebar" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SidebarSlide" Storyboard.TargetProperty="Y" From="14" To="0" Duration="0:0:0.35" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Main" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainSlide" Storyboard.TargetProperty="Y" From="14" To="0" Duration="0:0:0.35" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Footer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.32">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource Entrance}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ SLIM HEADER ═══ -->
        <Border x:Name="Header" Opacity="0" Background="{StaticResource Surface1}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R10}" Padding="20,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Text="CCP" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" FontFamily="{StaticResource Display}" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Background="{StaticResource Surface3}" CornerRadius="{StaticResource R100}" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="v0.2" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Medium"/>
                </Border>

                <!-- Selected peer info -->
                <TextBlock Grid.Column="2" Text="{Binding SelectedPeerLabel}" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="{StaticResource Mono}" VerticalAlignment="Center" Margin="20,0,0,0" TextTrimming="CharacterEllipsis"/>

                <!-- Status -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource StatusGreen}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding LocalStatus}" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Medium"/>
                </StackPanel>

                <!-- Refresh -->
                <Button Grid.Column="4" Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" FontSize="11"/>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ─── -->
            <Border x:Name="Sidebar" Opacity="0" Background="{StaticResource Surface1}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R10}" Padding="14">
                <Border.RenderTransform><TranslateTransform x:Name="SidebarSlide" Y="14"/></Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Nearby devices" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource Display}"/>
                        <TextBlock Text="Pair once, then browse from desktop." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Peers}" SelectedItem="{Binding SelectedPeer}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PeerView}">
                                <Border Background="{StaticResource Surface2}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R8}" Margin="0,0,0,6" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="30" Height="30" CornerRadius="{StaticResource R8}" Background="{StaticResource Surface3}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PlatformInitial}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DeviceName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="{Binding EndpointLabel}" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" FontFamily="{StaticResource Mono}"/>
                                            <TextBlock Text="{Binding TransportSummary}" FontSize="10" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Pair" Command="{Binding DataContext.PairCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Padding="10,5" FontSize="11" Margin="0,0,4,0"/>
                                            <Button Content="Send" Command="{Binding DataContext.SendFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Style="{StaticResource AccentBtn}" Padding="10,5" FontSize="11" IsEnabled="{Binding Trusted}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ─── MAIN PANEL ─── -->
            <Border x:Name="Main" Grid.Column="2" Opacity="0" Background="{StaticResource Surface1}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R10}" Padding="18,14">
                <Border.RenderTransform><TranslateTransform x:Name="MainSlide" Y="14"/></Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding PanelTitle}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource Display}"/>
                            <TextBlock Text="{Binding PanelSubtitle}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Reload" Command="{Binding RefreshPanelCommand}" Padding="10,5" FontSize="11"/>
                    </Grid>

                    <!-- Unified Stats Row -->
                    <Border Grid.Row="1" Background="{StaticResource Surface2}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R8}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="14,10">
                                <TextBlock Text="Battery" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                <TextBlock Text="{Binding BatteryText}" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderSubtle}" Margin="0,10"/>
                            <StackPanel Grid.Column="2" Margin="14,10">
                                <TextBlock Text="Storage" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                <TextBlock Text="{Binding StorageText}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource BorderSubtle}" Margin="0,10"/>
                            <StackPanel Grid.Column="4" Margin="14,10">
                                <TextBlock Text="Notifications" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                <TextBlock Text="{Binding NotificationAccessText}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Rectangle Grid.Column="5" Width="1" Fill="{StaticResource BorderSubtle}" Margin="0,10"/>
                            <StackPanel Grid.Column="6" Margin="14,10">
                                <TextBlock Text="Gallery" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                <TextBlock Text="{Binding GalleryAccessText}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Tabs -->
                    <TabControl Grid.Row="2" Style="{StaticResource TabCtrl}">
                        <TabItem Header="Overview" Style="{StaticResource TabBtn}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DeviceSettings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:RemoteFactView}">
                                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="4,9">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="Medium"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{StaticResource TextPrimary}" FontSize="12" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Gallery" Style="{StaticResource TabBtn}">
                            <ListBox ItemsSource="{Binding GalleryItems}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RemoteContentItem}">
                                        <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="4,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <TabItem Header="Files" Style="{StaticResource TabBtn}">
                            <ListBox ItemsSource="{Binding FileItems}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RemoteContentItem}">
                                        <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="4,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <TabItem Header="Notifications" Style="{StaticResource TabBtn}">
                            <ListBox ItemsSource="{Binding NotificationItems}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:RemoteContentItem}">
                                        <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="4,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <TabItem Header="Activity" Style="{StaticResource TabBtn}">
                            <ListBox ItemsSource="{Binding Events}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="4,8">
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ FOOTER ═══ -->
        <Border x:Name="Footer" Grid.Row="2" Opacity="0" Background="{StaticResource Surface1}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource R8}" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="6" Height="6" Fill="{StaticResource StatusGreen}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding FooterStatus}" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="{StaticResource Mono}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
